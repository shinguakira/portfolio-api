{
  "name": "@shinguakira/portfolio-api-types",
  "version": "1.2.0",
  "description": "TypeScript types for Shingu Akira Portfolio API responses",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
