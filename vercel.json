{
  "version": 2,
  "installCommand": "npm install && npm run build --workspace=packages/portfolio-api-types",
  "builds": [
    {
      "src": "ts/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "ts/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "/ts/public/images/$1"
    },
    {
      "src": "/icons/(.*)",
      "dest": "/ts/public/icons/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "/ts/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/ts/src/index.ts"
    }
  ]
}
