{
  "name": "portfolio-api-ts",
  "version": "1.0.0",
  "description": "API for Shingu Akira Portfolio (TypeScript/Elysia)",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx tsx src/index.ts",
    "dev:watch": "npx tsx watch src/index.ts",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "npm run format && npm run lint:fix"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/node": "^1.2.0",
    "@elysiajs/static": "^1.2.0",
    "@react-pdf/renderer": "^4.3.0",
    "@shinguakira/portfolio-api-types": "^1.0.0",
    "dotenv": "^16.0.3",
    "elysia": "^1.2.0"
  },
  "devDependencies": {
    "@azure/functions": "^4.7.3-beta.0",
    "@types/node": "^18.15.11",
    "@types/react": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "^3.2.4",
    "azure-function-express": "^2.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.2.5",
    "serverless-http": "^3.2.0",
    "serverless-offline": "^14.4.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.0.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
